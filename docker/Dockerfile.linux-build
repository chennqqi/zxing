FROM alpine:3.18

# Install GCC 12 (C++20 support), cmake, make, git
# zxing-cpp v3.0.0+ requires C++20
RUN apk add --no-cache \
    g++ \
    gcc \
    cmake \
    make \
    git \
    && mkdir -p /workspace

WORKDIR /workspace

CMD ["sh", "-c", "cmake -G 'Unix Makefiles' -DCMAKE_BUILD_TYPE=Release -DBUILD_STATIC_LIB=ON -DBUILD_SHARED_LIBS=OFF . && make -j$(nproc)"]
